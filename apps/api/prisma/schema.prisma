generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  OWNER
  MANAGER
  CASHIER
}

enum OrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  ECOCASH
  ZIPIT
  BANK_TRANSFER
  OTHER
  PAYNOW
}

enum PaymentRecordStatus {
  PENDING
  CONFIRMED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Merchant {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users             User[]
  userAuths         UserAuth[]
  roles             Role[]
  products          Product[]
  customers         Customer[]
  orders            Order[]
  orderItems        OrderItem[]
  payments          Payment[]
  stockMovements    StockMovement[]
  settings          Settings[]
  syncOperationLogs SyncOperationLog[]
  featureFlags      FeatureFlag[]
  auditLogs         AuditLog[]
  devices           Device[]
  paynowTransactions PaynowTransaction[]
}

model Role {
  id          String   @id @default(uuid())
  merchantId  String
  key         String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  users    User[]

  @@unique([merchantId, key])
  @@index([merchantId])
  @@index([updatedAt])
}

model User {
  id         String    @id @default(uuid())
  merchantId String
  roleId     String?
  identifier String    @unique
  pinHash    String
  role       RoleType  @default(OWNER)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  merchant  Merchant @relation(fields: [merchantId], references: [id])
  roleModel Role?    @relation(fields: [roleId], references: [id])

  userAuth UserAuth?
  devices  Device[]
  auditLogs AuditLog[]

  @@index([merchantId])
  @@index([updatedAt])
}

model UserAuth {
  id         String   @id @default(uuid())
  merchantId String
  userId     String   @unique
  identifier String
  pinHash    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([merchantId, identifier])
  @@index([merchantId])
  @@index([updatedAt])
}

model Device {
  id         String    @id @default(uuid())
  merchantId String
  userId     String
  deviceId   String
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([merchantId, deviceId])
  @@index([merchantId])
  @@index([updatedAt])
}

model Product {
  id                     String   @id
  merchantId             String
  name                   String
  price                  Decimal  @db.Decimal(12, 2)
  cost                   Decimal? @db.Decimal(12, 2)
  sku                    String?
  stockQty               Decimal  @db.Decimal(12, 3)
  lowStockThreshold      Decimal  @db.Decimal(12, 3)
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  items    OrderItem[]
  stockMovements StockMovement[]

  @@index([merchantId])
  @@index([updatedAt])
}

model Customer {
  id                     String   @id
  merchantId             String
  name                   String
  phone                  String?
  notes                  String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  orders   Order[]

  @@index([merchantId])
  @@index([updatedAt])
}

model Order {
  id                     String      @id
  merchantId             String
  customerId             String?
  orderNumber            String
  status                 OrderStatus
  subtotal               Decimal     @db.Decimal(12, 2)
  discountAmount         Decimal     @db.Decimal(12, 2)
  discountPercent        Decimal     @db.Decimal(5, 2)
  total                  Decimal     @db.Decimal(12, 2)
  notes                  String?
  confirmedAt            DateTime?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int         @default(1)
  lastModifiedByDeviceId String

  merchant  Merchant  @relation(fields: [merchantId], references: [id])
  customer  Customer? @relation(fields: [customerId], references: [id])
  items     OrderItem[]
  payments  Payment[]
  movements StockMovement[]
  paynowTransactions PaynowTransaction[]

  @@index([merchantId])
  @@index([updatedAt])
}

model OrderItem {
  id                     String   @id
  merchantId             String
  orderId                String
  productId              String
  quantity               Decimal  @db.Decimal(12, 3)
  unitPrice              Decimal  @db.Decimal(12, 2)
  lineTotal              Decimal  @db.Decimal(12, 2)
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model Payment {
  id                     String              @id
  merchantId             String
  orderId                String
  amount                 Decimal             @db.Decimal(12, 2)
  method                 PaymentMethod
  reference              String?
  paidAt                 DateTime
  status                 PaymentRecordStatus @default(CONFIRMED)
  paynowTransactionId    String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int                 @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model StockMovement {
  id                     String            @id
  merchantId             String
  productId              String
  type                   StockMovementType
  quantity               Decimal           @db.Decimal(12, 3)
  reason                 String?
  orderId                String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int               @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model Settings {
  id                     String   @id
  merchantId             String
  businessName           String
  currencyCode           String
  currencySymbol         String
  paymentInstructions    String
  whatsappTemplate       String
  supportPhone           String?
  supportEmail           String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId])
  @@index([merchantId])
  @@index([updatedAt])
}

model FeatureFlag {
  id         String   @id @default(uuid())
  key        String
  enabled    Boolean  @default(false)
  merchantId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@unique([key, merchantId])
  @@index([merchantId])
  @@index([updatedAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  merchantId String
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model SyncOperationLog {
  id         String   @id @default(uuid())
  merchantId String
  opId       String
  entityType String
  opType     String
  entityId   String
  payload    Json?
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, opId])
  @@index([merchantId])
  @@index([updatedAt])
}

model PaynowTransaction {
  id              String   @id @default(uuid())
  merchantId      String
  orderId         String
  amount          Decimal  @db.Decimal(12, 2)
  method          String
  phone           String?
  reference       String   @unique
  pollUrl         String
  redirectUrl     String?
  status          String
  rawInitResponse Json?
  rawLastStatus   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([orderId])
  @@index([updatedAt])
}
