  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@unique([key, merchantId])
  @@index([merchantId])
  @@index([updatedAt])
}

model AuditLog {
