  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model PublicCatalogOrder {
