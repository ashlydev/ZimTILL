generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  STOCK_CONTROLLER
  DELIVERY_RIDER
}

enum OrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum OrderSource {
  IN_STORE
  ONLINE
}

enum OrderDocumentType {
  ORDER
  QUOTE
  INVOICE
}

enum PaymentMethod {
  CASH
  ECOCASH
  ZIPIT
  BANK_TRANSFER
  OTHER
  PAYNOW
}

enum PaymentRecordStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum TransferStatus {
  DRAFT
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
}

model Merchant {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  phone              String?
  email              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  auditLogs          AuditLog[]
  branches           Branch[]
  catalogSettings    CatalogSettings?
  customers          Customer[]
  deliveries         Delivery[]
  devices            Device[]
  featureFlags       FeatureFlag[]
  orderItems         OrderItem[]
  orders             Order[]
  payments           Payment[]
  paynowTransactions PaynowTransaction[]
  productStocks      ProductStock[]
  products           Product[]
  publicCatalogOrders PublicCatalogOrder[]
  roles              Role[]
  settings           Settings[]
  stockMovements     StockMovement[]
  stockTransferItems StockTransferItem[]
  stockTransfers     StockTransfer[]
  subscriptions      Subscription[]
  syncOperationLogs  SyncOperationLog[]
  upgradeRequests    UpgradeRequest[]
  usageCounters      UsageCounter[]
  userAuths          UserAuth[]
  users              User[]
  restaurantTables   RestaurantTable[]
  kitchenTickets     KitchenTicket[]
  kitchenTicketItems KitchenTicketItem[]
  modifiers          Modifier[]
}

model Plan {
  id           String          @id @default(uuid())
  code         String          @unique
  name         String
  priceMonthly Decimal         @db.Decimal(12, 2)
  features     Json
  limits       Json
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  subscriptions Subscription[]
  requestedUpgrades UpgradeRequest[] @relation("RequestedPlan")
  currentUpgrades   UpgradeRequest[] @relation("CurrentPlan")
}

model Subscription {
  id                 String             @id @default(uuid())
  merchantId         String
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  cancelledAt        DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  plan     Plan     @relation(fields: [planId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model UsageCounter {
  id          String   @id @default(uuid())
  merchantId  String
  key         String
  periodStart DateTime
  periodEnd   DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, key, periodStart, periodEnd])
  @@index([merchantId])
  @@index([updatedAt])
}

model Branch {
  id        String   @id @default(uuid())
  merchantId String
  name      String
  address   String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  defaultUsers    User[]           @relation("UserDefaultBranch")
  devices         Device[]
  orders          Order[]
  payments        Payment[]
  paynowTransactions PaynowTransaction[]
  productStocks   ProductStock[]
  stockMovements  StockMovement[]
  transfersFrom   StockTransfer[]  @relation("TransferFromBranch")
  transfersTo     StockTransfer[]  @relation("TransferToBranch")
  deliveries      Delivery[]
  restaurantTables RestaurantTable[]
  kitchenTickets  KitchenTicket[]

  @@unique([merchantId, name])
  @@index([merchantId])
  @@index([updatedAt])
}

model Role {
  id          String   @id @default(uuid())
  merchantId  String
  key         String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  users    User[]

  @@unique([merchantId, key])
  @@index([merchantId])
  @@index([updatedAt])
}

model User {
  id              String    @id @default(uuid())
  merchantId      String
  roleId          String?
  defaultBranchId String?
  identifier      String    @unique
  pinHash         String
  role            RoleType  @default(OWNER)
  isActive        Boolean   @default(true)
  isPlatformAdmin Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  merchant         Merchant         @relation(fields: [merchantId], references: [id])
  roleModel        Role?            @relation(fields: [roleId], references: [id])
  defaultBranch    Branch?          @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id])
  userAuth         UserAuth?
  devices          Device[]
  auditLogs        AuditLog[]
  requestedTransfers StockTransfer[] @relation("RequestedTransferBy")
  approvedTransfers StockTransfer[]  @relation("ApprovedTransferBy")
  receivedTransfers StockTransfer[]  @relation("ReceivedTransferBy")
  assignedDeliveries Delivery[]
  upgradeRequests  UpgradeRequest[]

  @@index([merchantId])
  @@index([updatedAt])
}

model UserAuth {
  id         String   @id @default(uuid())
  merchantId String
  userId     String   @unique
  identifier String
  pinHash    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([merchantId, identifier])
  @@index([merchantId])
  @@index([updatedAt])
}

model Device {
  id            String    @id @default(uuid())
  merchantId    String
  userId        String
  deviceId      String
  name          String?
  activeBranchId String?
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  merchant     Merchant @relation(fields: [merchantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
  activeBranch Branch?  @relation(fields: [activeBranchId], references: [id])

  @@unique([merchantId, deviceId])
  @@index([merchantId])
  @@index([updatedAt])
}

model Product {
  id                     String   @id
  merchantId             String
  name                   String
  price                  Decimal  @db.Decimal(12, 2)
  cost                   Decimal? @db.Decimal(12, 2)
  sku                    String?
  category               String?
  imageUrl               String?
  stockQty               Decimal  @db.Decimal(12, 3)
  lowStockThreshold      Decimal  @db.Decimal(12, 3)
  isPublished            Boolean  @default(true)
  isActive               Boolean  @default(true)
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant        Merchant           @relation(fields: [merchantId], references: [id])
  items           OrderItem[]
  stockMovements  StockMovement[]
  productStocks   ProductStock[]
  stockTransferItems StockTransferItem[]
  kitchenTicketItems KitchenTicketItem[]

  @@index([merchantId])
  @@index([updatedAt])
}

model ProductStock {
  id                     String   @id @default(uuid())
  merchantId             String
  branchId               String
  productId              String
  qty                    Decimal  @db.Decimal(12, 3)
  lowStockThreshold      Decimal  @db.Decimal(12, 3)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([branchId, productId])
  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model Customer {
  id                     String   @id
  merchantId             String
  name                   String
  phone                  String?
  notes                  String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  orders   Order[]

  @@index([merchantId])
  @@index([updatedAt])
}

model Order {
  id                     String            @id
  merchantId             String
  branchId               String?
  customerId             String?
  orderNumber            String
  status                 OrderStatus
  documentType           OrderDocumentType @default(ORDER)
  source                 OrderSource       @default(IN_STORE)
  subtotal               Decimal           @db.Decimal(12, 2)
  discountAmount         Decimal           @db.Decimal(12, 2)
  discountPercent        Decimal           @db.Decimal(5, 2)
  total                  Decimal           @db.Decimal(12, 2)
  notes                  String?
  customerName           String?
  customerPhone          String?
  confirmedAt            DateTime?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int               @default(1)
  lastModifiedByDeviceId String

  merchant           Merchant            @relation(fields: [merchantId], references: [id])
  branch             Branch?             @relation(fields: [branchId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id])
  items              OrderItem[]
  payments           Payment[]
  movements          StockMovement[]
  paynowTransactions PaynowTransaction[]
  delivery           Delivery?
  publicCatalogOrder PublicCatalogOrder?
  kitchenTickets     KitchenTicket[]

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model OrderItem {
  id                     String   @id
  merchantId             String
  orderId                String
  productId              String
  quantity               Decimal  @db.Decimal(12, 3)
  unitPrice              Decimal  @db.Decimal(12, 2)
  lineTotal              Decimal  @db.Decimal(12, 2)
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model Payment {
  id                     String              @id
  merchantId             String
  branchId               String?
  orderId                String
  amount                 Decimal             @db.Decimal(12, 2)
  method                 PaymentMethod
  reference              String?
  paidAt                 DateTime
  status                 PaymentRecordStatus @default(CONFIRMED)
  paynowTransactionId    String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int                 @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model StockMovement {
  id                     String            @id
  merchantId             String
  branchId               String?
  productId              String
  type                   StockMovementType
  quantity               Decimal           @db.Decimal(12, 3)
  reason                 String?
  orderId                String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int               @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model StockTransfer {
  id                     String         @id @default(uuid())
  merchantId             String
  fromBranchId           String
  toBranchId             String
  status                 TransferStatus @default(DRAFT)
  requestedByUserId      String
  approvedByUserId       String?
  receivedByUserId       String?
  notes                  String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?
  version                Int            @default(1)
  lastModifiedByDeviceId String

  merchant   Merchant @relation(fields: [merchantId], references: [id])
  fromBranch Branch   @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranch   Branch   @relation("TransferToBranch", fields: [toBranchId], references: [id])
  requestedBy User    @relation("RequestedTransferBy", fields: [requestedByUserId], references: [id])
  approvedBy  User?   @relation("ApprovedTransferBy", fields: [approvedByUserId], references: [id])
  receivedBy  User?   @relation("ReceivedTransferBy", fields: [receivedByUserId], references: [id])
  items       StockTransferItem[]

  @@index([merchantId])
  @@index([updatedAt])
}

model StockTransferItem {
  id                     String   @id @default(uuid())
  merchantId             String
  transferId             String
  productId              String
  quantity               Decimal  @db.Decimal(12, 3)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant      @relation(fields: [merchantId], references: [id])
  transfer StockTransfer @relation(fields: [transferId], references: [id])
  product  Product       @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model Delivery {
  id                     String         @id @default(uuid())
  merchantId             String
  branchId               String?
  orderId                String         @unique
  assignedToUserId       String?
  status                 DeliveryStatus @default(PENDING)
  proofPhotoUrl          String?
  deliveredAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?
  version                Int            @default(1)
  lastModifiedByDeviceId String

  merchant   Merchant @relation(fields: [merchantId], references: [id])
  branch     Branch?  @relation(fields: [branchId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
  assignedTo User?    @relation(fields: [assignedToUserId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model Settings {
  id                     String   @id
  merchantId             String
  businessName           String
  currencyCode           String
  currencySymbol         String
  paymentInstructions    String
  whatsappTemplate       String
  supportPhone           String?
  supportEmail           String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId])
  @@index([merchantId])
  @@index([updatedAt])
}

model CatalogSettings {
  id                     String   @id @default(uuid())
  merchantId             String   @unique
  merchantSlug           String   @unique
  isEnabled              Boolean  @default(false)
  headline               String?
  description            String?
  checkoutPolicy         String   @default("CONFIRM_ON_PAID")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model PublicCatalogOrder {
  id            String   @id @default(uuid())
  merchantId    String
  orderId       String?  @unique
  customerName  String
  customerPhone String
  amount        Decimal  @db.Decimal(12, 2)
  status        String
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model FeatureFlag {
  id         String   @id @default(uuid())
  key        String
  enabled    Boolean  @default(false)
  merchantId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@unique([key, merchantId])
  @@index([merchantId])
  @@index([updatedAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  merchantId String
  branchId   String?
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model SyncOperationLog {
  id         String   @id @default(uuid())
  merchantId String
  opId       String
  entityType String
  opType     String
  entityId   String
  payload    Json?
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, opId])
  @@index([merchantId])
  @@index([updatedAt])
}

model PaynowTransaction {
  id              String   @id @default(uuid())
  merchantId      String
  branchId        String?
  orderId         String
  amount          Decimal  @db.Decimal(12, 2)
  method          String
  phone           String?
  reference       String   @unique
  pollUrl         String
  redirectUrl     String?
  status          String
  rawInitResponse Json?
  rawLastStatus   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([orderId])
  @@index([updatedAt])
}

model UpgradeRequest {
  id              String   @id @default(uuid())
  merchantId      String
  currentPlanId   String?
  requestedPlanId String?
  createdByUserId String?
  status          String   @default("OPEN")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant       Merchant @relation(fields: [merchantId], references: [id])
  currentPlan    Plan?    @relation("CurrentPlan", fields: [currentPlanId], references: [id])
  requestedPlan  Plan?    @relation("RequestedPlan", fields: [requestedPlanId], references: [id])
  createdByUser  User?    @relation(fields: [createdByUserId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model RestaurantTable {
  id         String   @id @default(uuid())
  merchantId String
  branchId   String
  name       String
  seats      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  tickets  KitchenTicket[]

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model KitchenTicket {
  id                String   @id @default(uuid())
  merchantId        String
  branchId          String
  orderId           String?
  restaurantTableId String?
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  branch          Branch           @relation(fields: [branchId], references: [id])
  order           Order?           @relation(fields: [orderId], references: [id])
  restaurantTable RestaurantTable? @relation(fields: [restaurantTableId], references: [id])
  items           KitchenTicketItem[]

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model KitchenTicketItem {
  id         String   @id @default(uuid())
  merchantId String
  ticketId   String
  productId  String?
  name       String
  qty        Decimal  @db.Decimal(12, 3)
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant Merchant      @relation(fields: [merchantId], references: [id])
  ticket   KitchenTicket @relation(fields: [ticketId], references: [id])
  product  Product?      @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model Modifier {
  id         String   @id @default(uuid())
  merchantId String
  name       String
  priceDelta Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}
