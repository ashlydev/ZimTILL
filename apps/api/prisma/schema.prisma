generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  STOCK_CONTROLLER
  DELIVERY_RIDER
}

enum OrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum OrderSource {
  IN_STORE
  ONLINE
}

enum OrderDocumentType {
  ORDER
  QUOTE
  INVOICE
}

enum PaymentMethod {
  CASH
  ECOCASH
  ZIPIT
  BANK_TRANSFER
  OTHER
  PAYNOW
}

enum PaymentRecordStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum TransferStatus {
  DRAFT
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
}

enum PurchaseStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

enum StockTakeStatus {
  DRAFT
  FINALIZED
}

enum CashUpStatus {
  OPEN
  SUBMITTED
  APPROVED
}

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  STOCK_TAKE_COMPLETED
  STOCK_VARIANCE
  SALE_COMPLETED
  CASH_UP_SUBMITTED
  CASH_UP_VARIANCE
  RETURN_CREATED
  DAMAGED_CREATED
  EXPIRED_CREATED
  SUSPICIOUS_ACTIVITY
  PURCHASE_RECEIVED
}

model Merchant {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  phone              String?
  email              String?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  auditLogs          AuditLog[]
  branches           Branch[]
  catalogSettings    CatalogSettings?
  customers          Customer[]
  categories         Category[]
  deliveries         Delivery[]
  devices            Device[]
  featureFlags       FeatureFlag[]
  suppliers          Supplier[]
  purchases          Purchase[]
  purchaseItems      PurchaseItem[]
  stockTakeSessions  StockTakeSession[]
  stockTakeItems     StockTakeItem[]
  cashUpSessions     CashUpSession[]
  notifications      AppNotification[]
  orderItems         OrderItem[]
  orders             Order[]
  payments           Payment[]
  paynowTransactions PaynowTransaction[]
  productStocks      ProductStock[]
  products           Product[]
  publicCatalogOrders PublicCatalogOrder[]
  roles              Role[]
  settings           Settings[]
  stockMovements     StockMovement[]
  stockTransferItems StockTransferItem[]
  stockTransfers     StockTransfer[]
  subscriptions      Subscription[]
  syncOperationLogs  SyncOperationLog[]
  upgradeRequests    UpgradeRequest[]
  usageCounters      UsageCounter[]
  userAuths          UserAuth[]
  users              User[]
  restaurantTables   RestaurantTable[]
  kitchenTickets     KitchenTicket[]
  kitchenTicketItems KitchenTicketItem[]
  modifiers          Modifier[]
}

model Plan {
  id           String          @id @default(uuid())
  code         String          @unique
  name         String
  priceMonthly Decimal         @db.Decimal(12, 2)
  features     Json
  limits       Json
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  subscriptions Subscription[]
  requestedUpgrades UpgradeRequest[] @relation("RequestedPlan")
  currentUpgrades   UpgradeRequest[] @relation("CurrentPlan")
}

model Subscription {
  id                 String             @id @default(uuid())
  merchantId         String
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  cancelledAt        DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  plan     Plan     @relation(fields: [planId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model UsageCounter {
  id          String   @id @default(uuid())
  merchantId  String
  key         String
  periodStart DateTime
  periodEnd   DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, key, periodStart, periodEnd])
  @@index([merchantId])
  @@index([updatedAt])
}

model Branch {
  id        String   @id @default(uuid())
  merchantId String
  name      String
  address   String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  defaultUsers    User[]           @relation("UserDefaultBranch")
  devices         Device[]
  orders          Order[]
  payments        Payment[]
  paynowTransactions PaynowTransaction[]
  productStocks   ProductStock[]
  suppliers       Supplier[]
  purchases       Purchase[]
  stockTakeSessions StockTakeSession[]
  cashUpSessions  CashUpSession[]
  notifications   AppNotification[]
  stockMovements  StockMovement[]
  transfersFrom   StockTransfer[]  @relation("TransferFromBranch")
  transfersTo     StockTransfer[]  @relation("TransferToBranch")
  deliveries      Delivery[]
  restaurantTables RestaurantTable[]
  kitchenTickets  KitchenTicket[]

  @@unique([merchantId, name])
  @@index([merchantId])
  @@index([updatedAt])
}

model Role {
  id          String   @id @default(uuid())
  merchantId  String
  key         String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  users    User[]

  @@unique([merchantId, key])
  @@index([merchantId])
  @@index([updatedAt])
}

model User {
  id              String    @id @default(uuid())
  merchantId      String
  roleId          String?
  defaultBranchId String?
  identifier      String    @unique
  pinHash         String
  role            RoleType  @default(OWNER)
  isActive        Boolean   @default(true)
  isPlatformAdmin Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  merchant         Merchant         @relation(fields: [merchantId], references: [id])
  roleModel        Role?            @relation(fields: [roleId], references: [id])
  defaultBranch    Branch?          @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id])
  userAuth         UserAuth?
  devices          Device[]
  auditLogs        AuditLog[]
  createdProducts  Product[]         @relation("ProductCreatedBy")
  updatedProducts  Product[]         @relation("ProductUpdatedBy")
  createdCustomers Customer[]        @relation("CustomerCreatedBy")
  updatedCustomers Customer[]        @relation("CustomerUpdatedBy")
  createdOrders    Order[]           @relation("OrderCreatedBy")
  updatedOrders    Order[]           @relation("OrderUpdatedBy")
  createdOrderItems OrderItem[]      @relation("OrderItemCreatedBy")
  updatedOrderItems OrderItem[]      @relation("OrderItemUpdatedBy")
  createdPayments  Payment[]         @relation("PaymentCreatedBy")
  updatedPayments  Payment[]         @relation("PaymentUpdatedBy")
  createdMovements StockMovement[]   @relation("StockMovementCreatedBy")
  updatedMovements StockMovement[]   @relation("StockMovementUpdatedBy")
  createdSettings  Settings[]        @relation("SettingsCreatedBy")
  updatedSettings  Settings[]        @relation("SettingsUpdatedBy")
  createdPaynowTransactions PaynowTransaction[] @relation("PaynowTransactionCreatedBy")
  updatedPaynowTransactions PaynowTransaction[] @relation("PaynowTransactionUpdatedBy")
  createdSuppliers Supplier[]       @relation("SupplierCreatedBy")
  updatedSuppliers Supplier[]       @relation("SupplierUpdatedBy")
  createdPurchases Purchase[]       @relation("PurchaseCreatedBy")
  updatedPurchases Purchase[]       @relation("PurchaseUpdatedBy")
  countedStockTakes StockTakeSession[] @relation("StockTakeCountedBy")
  finalizedStockTakes StockTakeSession[] @relation("StockTakeFinalizedBy")
  cashUpSessions CashUpSession[]    @relation("CashUpUser")
  approvedCashUps CashUpSession[]   @relation("CashUpApprovedBy")
  notifications  AppNotification[]
  requestedTransfers StockTransfer[] @relation("RequestedTransferBy")
  approvedTransfers StockTransfer[]  @relation("ApprovedTransferBy")
  receivedTransfers StockTransfer[]  @relation("ReceivedTransferBy")
  assignedDeliveries Delivery[]
  upgradeRequests  UpgradeRequest[]

  @@index([merchantId])
  @@index([updatedAt])
}

model UserAuth {
  id         String   @id @default(uuid())
  merchantId String
  userId     String   @unique
  identifier String
  pinHash    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([merchantId, identifier])
  @@index([merchantId])
  @@index([updatedAt])
}

model Device {
  id            String    @id @default(uuid())
  merchantId    String
  userId        String
  deviceId      String
  name          String?
  activeBranchId String?
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  merchant     Merchant @relation(fields: [merchantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
  activeBranch Branch?  @relation(fields: [activeBranchId], references: [id])

  @@unique([merchantId, deviceId])
  @@index([merchantId])
  @@index([updatedAt])
}

model Category {
  id                     String   @id
  merchantId             String
  createdByUserId        String?
  updatedByUserId        String?
  name                   String
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant   Merchant   @relation(fields: [merchantId], references: [id])
  products   Product[]  @relation("ProductCategory")
  stockTakeSessions StockTakeSession[]

  @@index([merchantId])
  @@index([merchantId, name])
  @@index([updatedAt])
}

model Product {
  id                     String   @id
  merchantId             String
  categoryId             String?
  createdByUserId        String?
  updatedByUserId        String?
  name                   String
  price                  Decimal  @db.Decimal(12, 2)
  cost                   Decimal? @db.Decimal(12, 2)
  sku                    String?
  category               String?
  imageUrl               String?
  stockQty               Decimal  @db.Decimal(12, 3)
  lowStockThreshold      Decimal  @db.Decimal(12, 3)
  isPublished            Boolean  @default(true)
  isActive               Boolean  @default(true)
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant        Merchant           @relation(fields: [merchantId], references: [id])
  categoryRef     Category?          @relation("ProductCategory", fields: [categoryId], references: [id])
  createdByUser   User?              @relation("ProductCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser   User?              @relation("ProductUpdatedBy", fields: [updatedByUserId], references: [id])
  items           OrderItem[]
  stockMovements  StockMovement[]
  productStocks   ProductStock[]
  purchaseItems   PurchaseItem[]
  stockTakeItems  StockTakeItem[]
  stockTransferItems StockTransferItem[]
  kitchenTicketItems KitchenTicketItem[]

  @@index([merchantId])
  @@index([categoryId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([updatedAt])
}

model ProductStock {
  id                     String   @id @default(uuid())
  merchantId             String
  branchId               String
  productId              String
  qty                    Decimal  @db.Decimal(12, 3)
  lowStockThreshold      Decimal  @db.Decimal(12, 3)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([branchId, productId])
  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model Customer {
  id                     String   @id
  merchantId             String
  createdByUserId        String?
  updatedByUserId        String?
  name                   String
  phone                  String?
  notes                  String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  createdByUser User?   @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User?   @relation("CustomerUpdatedBy", fields: [updatedByUserId], references: [id])
  orders   Order[]

  @@index([merchantId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([updatedAt])
}

model Order {
  id                     String            @id
  merchantId             String
  branchId               String?
  customerId             String?
  createdByUserId        String?
  updatedByUserId        String?
  orderNumber            String
  status                 OrderStatus
  documentType           OrderDocumentType @default(ORDER)
  source                 OrderSource       @default(IN_STORE)
  subtotal               Decimal           @db.Decimal(12, 2)
  discountAmount         Decimal           @db.Decimal(12, 2)
  discountPercent        Decimal           @db.Decimal(5, 2)
  total                  Decimal           @db.Decimal(12, 2)
  notes                  String?
  customerName           String?
  customerPhone          String?
  confirmedAt            DateTime?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int               @default(1)
  lastModifiedByDeviceId String

  merchant           Merchant            @relation(fields: [merchantId], references: [id])
  branch             Branch?             @relation(fields: [branchId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id])
  createdByUser      User?               @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser      User?               @relation("OrderUpdatedBy", fields: [updatedByUserId], references: [id])
  items              OrderItem[]
  payments           Payment[]
  movements          StockMovement[]
  paynowTransactions PaynowTransaction[]
  delivery           Delivery?
  publicCatalogOrder PublicCatalogOrder?
  kitchenTickets     KitchenTicket[]

  @@index([merchantId])
  @@index([branchId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([updatedAt])
}

model OrderItem {
  id                     String   @id
  merchantId             String
  orderId                String
  productId              String
  createdByUserId        String?
  updatedByUserId        String?
  quantity               Decimal  @db.Decimal(12, 3)
  unitPrice              Decimal  @db.Decimal(12, 2)
  lineTotal              Decimal  @db.Decimal(12, 2)
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  createdByUser User? @relation("OrderItemCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User? @relation("OrderItemUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([merchantId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([updatedAt])
}

model Payment {
  id                     String              @id
  merchantId             String
  branchId               String?
  orderId                String
  createdByUserId        String?
  updatedByUserId        String?
  amount                 Decimal             @db.Decimal(12, 2)
  method                 PaymentMethod
  reference              String?
  paidAt                 DateTime
  status                 PaymentRecordStatus @default(CONFIRMED)
  paynowTransactionId    String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int                 @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
  createdByUser User? @relation("PaymentCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User? @relation("PaymentUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([updatedAt])
}

model StockMovement {
  id                     String            @id
  merchantId             String
  branchId               String?
  productId              String
  createdByUserId        String?
  updatedByUserId        String?
  type                   StockMovementType
  quantity               Decimal           @db.Decimal(12, 3)
  reason                 String?
  orderId                String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int               @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])
  createdByUser User? @relation("StockMovementCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User? @relation("StockMovementUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([updatedAt])
}

model StockTransfer {
  id                     String         @id @default(uuid())
  merchantId             String
  fromBranchId           String
  toBranchId             String
  status                 TransferStatus @default(DRAFT)
  requestedByUserId      String
  approvedByUserId       String?
  receivedByUserId       String?
  notes                  String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?
  version                Int            @default(1)
  lastModifiedByDeviceId String

  merchant   Merchant @relation(fields: [merchantId], references: [id])
  fromBranch Branch   @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranch   Branch   @relation("TransferToBranch", fields: [toBranchId], references: [id])
  requestedBy User    @relation("RequestedTransferBy", fields: [requestedByUserId], references: [id])
  approvedBy  User?   @relation("ApprovedTransferBy", fields: [approvedByUserId], references: [id])
  receivedBy  User?   @relation("ReceivedTransferBy", fields: [receivedByUserId], references: [id])
  items       StockTransferItem[]

  @@index([merchantId])
  @@index([updatedAt])
}

model StockTransferItem {
  id                     String   @id @default(uuid())
  merchantId             String
  transferId             String
  productId              String
  quantity               Decimal  @db.Decimal(12, 3)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant      @relation(fields: [merchantId], references: [id])
  transfer StockTransfer @relation(fields: [transferId], references: [id])
  product  Product       @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model Delivery {
  id                     String         @id @default(uuid())
  merchantId             String
  branchId               String?
  orderId                String         @unique
  assignedToUserId       String?
  status                 DeliveryStatus @default(PENDING)
  proofPhotoUrl          String?
  deliveredAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?
  version                Int            @default(1)
  lastModifiedByDeviceId String

  merchant   Merchant @relation(fields: [merchantId], references: [id])
  branch     Branch?  @relation(fields: [branchId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
  assignedTo User?    @relation(fields: [assignedToUserId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model Supplier {
  id                     String   @id @default(uuid())
  merchantId             String
  branchId               String?
  createdByUserId        String?
  updatedByUserId        String?
  name                   String
  phone                  String?
  email                  String?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  lastModifiedByDeviceId String   @default("server-supplier")

  merchant      Merchant   @relation(fields: [merchantId], references: [id])
  branch        Branch?    @relation(fields: [branchId], references: [id])
  createdByUser User?      @relation("SupplierCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User?      @relation("SupplierUpdatedBy", fields: [updatedByUserId], references: [id])
  purchases     Purchase[]

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model Purchase {
  id                     String         @id @default(uuid())
  merchantId             String
  branchId               String?
  supplierId             String?
  createdByUserId        String?
  updatedByUserId        String?
  status                 PurchaseStatus @default(DRAFT)
  reference              String?
  notes                  String?
  totalCost              Decimal        @db.Decimal(12, 2)
  receivedAt             DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?
  lastModifiedByDeviceId String         @default("server-purchase")

  merchant      Merchant       @relation(fields: [merchantId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  createdByUser User?          @relation("PurchaseCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User?          @relation("PurchaseUpdatedBy", fields: [updatedByUserId], references: [id])
  items         PurchaseItem[]

  @@index([merchantId])
  @@index([branchId])
  @@index([supplierId])
  @@index([updatedAt])
}

model PurchaseItem {
  id                     String   @id @default(uuid())
  merchantId             String
  purchaseId             String
  productId              String
  quantity               Decimal  @db.Decimal(12, 3)
  unitCost               Decimal  @db.Decimal(12, 2)
  lineTotal              Decimal  @db.Decimal(12, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  lastModifiedByDeviceId String   @default("server-purchase-item")

  merchant Merchant @relation(fields: [merchantId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model StockTakeSession {
  id                     String          @id @default(uuid())
  merchantId             String
  branchId               String?
  categoryId             String?
  status                 StockTakeStatus @default(DRAFT)
  name                   String
  notes                  String?
  countedByUserId        String?
  finalizedByUserId      String?
  startedAt              DateTime        @default(now())
  finalizedAt            DateTime?
  varianceQty            Decimal         @default(0) @db.Decimal(12, 3)
  varianceValue          Decimal         @default(0) @db.Decimal(12, 2)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  deletedAt              DateTime?
  lastModifiedByDeviceId String          @default("server-stocktake")

  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  category        Category?        @relation(fields: [categoryId], references: [id])
  countedByUser   User?            @relation("StockTakeCountedBy", fields: [countedByUserId], references: [id])
  finalizedByUser User?            @relation("StockTakeFinalizedBy", fields: [finalizedByUserId], references: [id])
  items           StockTakeItem[]

  @@index([merchantId])
  @@index([branchId])
  @@index([categoryId])
  @@index([updatedAt])
}

model StockTakeItem {
  id                     String   @id @default(uuid())
  merchantId             String
  sessionId              String
  productId              String
  systemQty              Decimal  @db.Decimal(12, 3)
  countedQty             Decimal  @db.Decimal(12, 3)
  varianceQty            Decimal  @db.Decimal(12, 3)
  varianceValue          Decimal  @db.Decimal(12, 2)
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  lastModifiedByDeviceId String   @default("server-stocktake-item")

  merchant Merchant         @relation(fields: [merchantId], references: [id])
  session  StockTakeSession @relation(fields: [sessionId], references: [id])
  product  Product          @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([updatedAt])
}

model CashUpSession {
  id                     String       @id @default(uuid())
  merchantId             String
  branchId               String?
  userId                 String
  approvedByUserId       String?
  status                 CashUpStatus @default(OPEN)
  openingFloat           Decimal      @db.Decimal(12, 2)
  expectedCash           Decimal      @default(0) @db.Decimal(12, 2)
  countedCash            Decimal?     @db.Decimal(12, 2)
  variance               Decimal?     @db.Decimal(12, 2)
  notes                  String?
  openedAt               DateTime     @default(now())
  submittedAt            DateTime?
  approvedAt             DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  deletedAt              DateTime?
  lastModifiedByDeviceId String       @default("server-cashup")

  merchant       Merchant @relation(fields: [merchantId], references: [id])
  branch         Branch?  @relation(fields: [branchId], references: [id])
  user           User     @relation("CashUpUser", fields: [userId], references: [id])
  approvedByUser User?    @relation("CashUpApprovedBy", fields: [approvedByUserId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([updatedAt])
}

model AppNotification {
  id         String           @id @default(uuid())
  merchantId String
  branchId   String?
  userId     String?
  type       NotificationType
  title      String
  message    String
  entityType String?
  entityId   String?
  severity   String           @default("info")
  visibility String           @default("MANAGEMENT")
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([merchantId])
  @@index([branchId])
  @@index([userId])
  @@index([updatedAt])
}

model Settings {
  id                     String   @id
  merchantId             String
  createdByUserId        String?
  updatedByUserId        String?
  businessName           String
  currencyCode           String
  currencySymbol         String
  paymentInstructions    String
  whatsappTemplate       String
  supportPhone           String?
  supportEmail           String?
  createdAt              DateTime
  updatedAt              DateTime
  deletedAt              DateTime?
  version                Int      @default(1)
  lastModifiedByDeviceId String

  merchant Merchant @relation(fields: [merchantId], references: [id])
  createdByUser User?   @relation("SettingsCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User?   @relation("SettingsUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([merchantId])
  @@index([merchantId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([updatedAt])
